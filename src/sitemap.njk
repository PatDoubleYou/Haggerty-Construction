---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {%- for page in collections.all %}
  {%- if page.url and page.url != '/admin/' and page.url != '/pages/weather-stripping-special/' %}
  <url>
    <loc>https://{{ client.domain }}{{ page.url }}</loc>
    <lastmod>{{ page.date.toISOString() }}</lastmod>
    <changefreq>{% if page.url == '/' %}weekly{% else %}monthly{% endif %}</changefreq>
    <priority>{% if page.url == '/' %}1.0{% elif '/gallery/' in page.url %}0.9{% elif '/blog/' in page.url %}0.8{% else %}0.7{% endif %}</priority>
  </url>
  {%- endif %}
  {%- endfor %}
</urlset>
